# Copy to .env in repo root (not docker/.env)
# FOUNDRY_USERDATA_HOST must match userDataPath in fvtt.config.js
# Values with # must be quoted: FOUNDRY_PASSWORD='pass#word'

FOUNDRY_USERDATA_HOST=/Users/yourname/foundrydata

# World folder id (not display title) — matches install-quench / testWorldName slug
FOUNDRY_WORLD=modern-names-test

FOUNDRY_USERNAME=foundry
FOUNDRY_PASSWORD=foundry
FOUNDRY_ADMIN_KEY=foundry

# Optional — felddy image can use these instead of docker/secret/Config
# FOUNDRY_LICENSE_KEY=
